#!/usr/bin/env bash
# Uber Modern Microservices Architecture Demo Script
# Generators and metrics are declared in modern.sdl — this recipe handles dynamic scenarios.
#
# SDL system block provides:
#   generator("baseline", arch.gateway.RequestRide, rate(100))
#   generator("drivers", arch.gateway.UpdateDriverLocation, rate(1000))
#   metric("request_latency", ...), metric("location_lookup", ...), metric("notification_send", ...)

export SDL_CANVAS_ID=default

sdl canvas create $SDL_CANVAS_ID
sdl canvas reset $SDL_CANVAS_ID

function execWithConfirm() {
  msg=$1; shift
  cmd=$1; shift
  args=$*
  echo ""
  echo "    >    $cmd $args"
  echo ""
  echo "$msg ... Press enter to continue"
  if [ "$START_PROMPTING" == "true" ]; then
    read
  fi
  $cmd $args
}

echo "=== Uber Modern Architecture Demo ==="
echo "Event-driven, globally distributed architecture."
execWithConfirm "Loading the modern system" sdl load examples/uber/modern.sdl
execWithConfirm "Activate the UberModern system" sdl use UberModern

# Generators and metrics auto-created from SDL on Use()

echo ""
echo "=== Architecture ==="
echo "1. Event-driven with Kafka-like event bus"
echo "2. Microservices with dedicated databases"
echo "3. ML-powered matching"
echo "4. Real-time analytics with stream processing"
echo "5. Circuit breakers and rate limiting"
echo ""
echo "Baseline: 100 RPS rides + 1000 RPS driver updates (from SDL)"
echo "Press enter to continue..."
read

START_PROMPTING=true

echo "=== Peak Hours (1000 RPS) ==="
execWithConfirm "Adding peak traffic (900 RPS additional)" sdl gen add peak gateway.RequestRide 900 --apply-flows
execWithConfirm "Starting peak" sdl gen start peak --apply-flows

echo ""
echo "1000 RPS - 50x MVP breaking point! Still <60ms latency."
echo "Press enter for surge..."
read

echo "=== Regional Surge (2000 RPS) ==="
execWithConfirm "Adding surge (1000 RPS additional)" sdl gen add surge gateway.RequestRide 1000 --apply-flows
execWithConfirm "Starting surge" sdl gen start surge --apply-flows

echo ""
echo "2000 RPS handled gracefully. Rate limiter protecting from abuse."
echo "Press enter for resilience demo..."
read

echo "=== Resilience: Read Replica Failure ==="
execWithConfirm "Increasing read replica latency" sdl set gateway.userService.readDB.pool.AcquireLatency 500ms

echo ""
echo "Circuit breaker: fails fast, serves from cache, partial degradation."
echo "Press enter to restore..."
read

execWithConfirm "Restoring read replica" sdl set gateway.userService.readDB.pool.AcquireLatency 1ms

echo "=== Extreme Scale (5000 RPS) ==="
execWithConfirm "Stopping surge" sdl gen stop surge --apply-flows
execWithConfirm "Stopping peak" sdl gen stop peak --apply-flows
execWithConfirm "Adding extreme (5000 RPS)" sdl gen add extreme gateway.RequestRide 5000 --apply-flows
execWithConfirm "Starting extreme" sdl gen start extreme --apply-flows

echo ""
echo "250x MVP load! Gateway queuing, rate limiter active, but <150ms for accepted requests."
echo "Press enter to clean up..."
read

execWithConfirm "Stopping all" sdl gen stop --all

echo ""
echo "=== Evolution Summary ==="
echo "MVP:          20 RPS,   350ms, $50/mo"
echo "Intermediate: 300 RPS,  150ms, $205/mo"
echo "Modern:       5000 RPS, 50ms,  $15,300/mo"
echo ""
echo "Demo complete."
