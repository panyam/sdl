#!/usr/bin/env bash
# Uber Intermediate Architecture Demo Script
# Generators and metrics are declared in intermediate.sdl — this recipe handles dynamic scenarios.
#
# SDL system block provides:
#   generator("baseline", arch.gateway.RequestRide, rate(20))
#   generator("drivers", arch.gateway.UpdateDriverLocation, rate(50))
#   metric("request_latency", ...), metric("driver_query", ...), metric("notification_latency", ...)

export SDL_CANVAS_ID=default

sdl canvas create $SDL_CANVAS_ID
sdl canvas reset $SDL_CANVAS_ID

function execWithConfirm() {
  msg=$1; shift
  cmd=$1; shift
  args=$*
  echo ""
  echo "    >    $cmd $args"
  echo ""
  echo "$msg ... Press enter to continue"
  if [ "$START_PROMPTING" == "true" ]; then
    read
  fi
  $cmd $args
}

echo "=== Uber Intermediate Architecture Demo ==="
echo "After the MVP started breaking under load, the team made strategic improvements."
execWithConfirm "Loading the intermediate system" sdl load examples/uber/intermediate.sdl
execWithConfirm "Activate the UberIntermediate system" sdl use UberIntermediate

# Generators and metrics auto-created from SDL on Use()

echo ""
echo "=== Key Improvements ==="
echo "1. Redis caching (70% users, 90% driver locations)"
echo "2. Service split: User, Driver, Matching, Notification"
echo "3. Geo-indexed queries (30ms vs 200ms)"
echo "4. Async notifications"
echo "5. Better pooling (20 connections vs 3)"
echo ""
echo "Baseline traffic running at 20 RPS + 50 RPS drivers (from SDL)"
echo "Press enter to continue..."
read

START_PROMPTING=true

echo "=== Morning Rush (100 RPS Total) ==="
execWithConfirm "Adding morning rush (80 RPS additional)" sdl gen add morning_rush gateway.RequestRide 80
execWithConfirm "Starting morning rush" sdl gen start morning_rush

echo ""
echo "Handling 100 RPS - 5x the MVP breaking point!"
echo "- Still <200ms latency, caches warm, no failures"
echo "Press enter to push further..."
read

echo "=== Surge (200 RPS Total) ==="
execWithConfirm "Adding surge (100 RPS additional)" sdl gen add surge gateway.RequestRide 100
execWithConfirm "Starting surge" sdl gen start surge

echo ""
echo "200 RPS - 10x MVP! Latency rising but still processing."
echo "Press enter for extreme load..."
read

execWithConfirm "Stopping surge" sdl gen stop surge
execWithConfirm "Adding extreme load (300 RPS)" sdl gen add extreme gateway.RequestRide 300
execWithConfirm "Starting extreme" sdl gen start extreme

echo ""
echo "At 300+ RPS we finally see failures. 15x MVP load to break!"
echo "Press enter for cache demo..."
read

execWithConfirm "Stopping all generators" sdl gen stop --all

echo ""
echo "=== Cache Impact Demo ==="
execWithConfirm "Reducing user cache to 10%" sdl set gateway.userService.redis.HitRate 0.1
execWithConfirm "Reducing driver cache to 10%" sdl set gateway.driverService.locationCache.HitRate 0.1
execWithConfirm "Restarting baseline (20 RPS)" sdl gen start baseline

echo ""
echo "Without caching: latency 300ms+, database under heavy load"
echo "Press enter to restore..."
read

execWithConfirm "Restoring user cache" sdl set gateway.userService.redis.HitRate 0.7
execWithConfirm "Restoring driver cache" sdl set gateway.driverService.locationCache.HitRate 0.9

echo ""
echo "=== Takeaways ==="
echo "- 15x capacity, 60% latency reduction"
echo "- Service isolation, async processing, caching"
echo "- Still has: monolithic DBs, no regional distribution"
echo ""
execWithConfirm "Stopping all" sdl gen stop --all
echo "Demo complete."
