#!/usr/bin/env bash
# Uber MVP Demo Script
# Generators and metrics are declared in mvp.sdl — this recipe handles dynamic scenarios.
#
# SDL system block provides:
#   generator("baseline", arch.webserver.RequestRide, rate(5))
#   generator("drivers", arch.webserver.UpdateLocation, rate(10))
#   metric("request_latency", arch.webserver.RequestRide, "latency", "p90", 1s)
#   metric("maps_latency", arch.mapsService.CalculateRoute, "latency", "p90", 1s)
#   metric("db_query", arch.database.FindNearestDriver, "latency", "p90", 1s)

export SDL_CANVAS_ID=default

sdl canvas create $SDL_CANVAS_ID
sdl canvas reset $SDL_CANVAS_ID

function execWithConfirm() {
  msg=$1; shift
  cmd=$1; shift
  args=$*
  echo ""
  echo "    >    $cmd $args"
  echo ""
  echo "$msg ... Press enter to continue"
  if [ "$START_PROMPTING" == "true" ]; then
    read
  fi
  $cmd $args
}

echo "=== Uber MVP Demo - 'Two friends with an app' ==="
execWithConfirm "Loading the MVP system" sdl load examples/uber/mvp.sdl
execWithConfirm "Activate the UberMVP system" sdl use UberMVP

# Generators and metrics are auto-created from SDL on Use()

echo "=== Setting Pool Parameters ==="
execWithConfirm "Setting database pool hold time" sdl set database.pool.AvgHoldTime 0.15
execWithConfirm "Setting maps API hold time" sdl set mapsService.pool.AvgHoldTime 0.1

echo ""
echo "=== Baseline Traffic ==="
echo "Traffic running at 5 RPS rides + 10 RPS driver updates (from SDL)"
echo "Press enter to continue..."
read

echo "=== Morning Rush Hour (20 RPS) ==="
execWithConfirm "Updating baseline to 20 RPS" sdl gen update baseline 20 --apply-flows

echo ""
echo "=== System Under Stress ==="
echo "Observe:"
echo "- Database queries taking longer (connection pool contention)"
echo "- Latency spikes to 500-600ms"
echo "- Some requests start failing"
echo "Press enter to simulate surge..."
read

echo "=== Surge Event (50 RPS) ==="
execWithConfirm "Updating baseline to 50 RPS" sdl gen update baseline 50 --apply-flows

echo ""
echo "=== System Breakdown ==="
echo "- Massive failure rate (>50%)"
echo "- Database completely overwhelmed"
echo "Press enter to stop..."
read

echo "=== Recovery ==="
execWithConfirm "Reducing to 5 RPS" sdl gen update baseline 5 --apply-flows
execWithConfirm "Stopping driver updates" sdl gen stop drivers --apply-flows

echo ""
echo "=== Disaster: Maps API Outage ==="
echo "Press enter to simulate slow Maps API..."
read

execWithConfirm "Making Maps API slow (2s latency)" sdl set mapsService.pool.AcquireLatency 2000ms
execWithConfirm "Restarting baseline traffic" sdl gen start baseline --apply-flows

echo ""
echo "With Maps API slow, everything grinds to a halt!"
echo "Press enter to restore..."
read

execWithConfirm "Restoring Maps API" sdl set mapsService.pool.AcquireLatency 10ms
execWithConfirm "Stopping all generators" sdl gen stop --all

echo ""
echo "=== Key Problems ==="
echo "1. No Caching"
echo "2. No Indexes (full table scan)"
echo "3. Tiny Connection Pool"
echo "4. Synchronous Everything"
echo "5. No Fault Isolation"
echo ""
echo "Demo complete."
