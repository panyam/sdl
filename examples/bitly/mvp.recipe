#!/usr/bin/env bash
# Bitly MVP Demo Script
# Generators and metrics are declared in mvp.sdl — this recipe handles dynamic scenarios.

sdl load examples/bitly/mvp.sdl
sdl use Bitly

# Generators and metrics auto-created from SDL system block:
#   generator("baseline", arch.app.Shorten, rate(5))
#   metric("shorten_latency", arch.app.Shorten, "latency", "p90", 1s)
#   metric("redirect_latency", arch.app.Redirect, "latency", "p90", 1s)

echo "=== Bitly MVP Demo ==="
echo "Baseline traffic running at 5 RPS (from SDL declaration)"
echo ""

echo "=== Ramp Up (20 RPS) ==="
echo "Simulating increased traffic..."
sdl gen update baseline 20 --apply-flows

echo ""
echo "=== Surge (50 RPS) ==="
echo "Database getting overwhelmed..."
sdl gen update baseline 50 --apply-flows

echo ""
echo "=== Back to Baseline ==="
sdl gen update baseline 5 --apply-flows

echo ""
echo "Stopping all generators..."
sdl gen stop --all

echo ""
echo "Demo complete."
