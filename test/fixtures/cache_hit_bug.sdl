// Test case for cache hit rate bug
// Expected: 80% cache hit rate should result in ~20% of traffic to database
// Bug: Currently results in ~99% of traffic to database

component SimplifiedCache {
    param hit_rate Float = 0.8

    uses db Database()

    method Get() Bool {
        // Early return pattern that confuses FlowEval
        if self.hit_rate > 0.5 {
            return true
        }

        // This should only see 20% of traffic
        return self.db.Query()
    }
}

component Database {
    method Query() Bool {
        return true
    }
}

component CacheHitBugArch {
    uses cache SimplifiedCache(hit_rate = 0.8)
    uses database Database()
}

system CacheHitBugTest(arch CacheHitBugArch) {
}
